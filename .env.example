# --- API KEYS ---
OPENAI_API_KEY=
DATALASTIC_API_KEY=
ADSB_API_KEY=

## Feature switches
ENABLE_VISION_API=false
ENABLE_DATALASTIC_API=false
ENABLE_ADSB_API=true

# --- DRONE OPERATION MODE ---
# 'virtual'  → reads local VIDEO_PATH MP4 in a loop (default, safe for dev)
# 'real'     → reads live RTSP from the real drone camera
DRONE_MODE=virtual

# Required when DRONE_MODE=real — set to the RTSP stream URL from your drone remote controller:
# Example DJI:  rtsp://192.168.1.1:554/live
# Example SIYI: rtsp://192.168.144.25:8554/main.264
REAL_DRONE_RTSP_URL=rtsp://[DRONE_IP]:[PORT]/live