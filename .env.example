# --- API KEYS ---
OPENAI_API_KEY=
DATALASTIC_API_KEY=
ADSB_API_KEY=
HF_TOKEN=
OPENWEATHER_API_KEY=

## Switch
ENABLE_VISION_API=false
ENABLE_DATALASTIC_API=false
ENABLE_ADSB_API=false

DRONE_MODE=virtual

# ── REAL MODE: URL RTSP live drone (ganti sesuai IP kamera drone) ─
REAL_DRONE_RTSP_URL=

MAVLINK_URL=udpin:0.0.0.0:14550

# Suppress Go DroneSimulator — prevents race vs real_telemetry_bridge on same asset_id
DISABLE_DRONE_SIM=true

# ==========================================
# DEVOPS — Project & Ports
# ==========================================
COMPOSE_PROJECT_NAME=mariview

PORT_POSTGRES=5433
PORT_KEYCLOAK=8082
PORT_INFLUX=8087
PORT_NATS=4223
PORT_NATS_MGT=8223
PORT_RTSP=8555
PORT_RTMP=1936
PORT_HLS=8889
PORT_MTX_API=9998
PORT_MINIO=9002
PORT_MINIO_UI=9003
PORT_CORE=8090
PORT_UI=3001
PORT_MAVLINK=14551

# ==========================================
# CREDENTIALS — Wajib diisi, JANGAN commit!
# ==========================================
# PostgreSQL
DB_USER=root
DB_PASSWORD=CHANGE_ME

# Keycloak Admin Console
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_CLIENT_ID=chimp-platform

# InfluxDB
INFLUX_USER=admin
INFLUX_PASSWORD=CHANGE_ME
INFLUX_ORG=locallitix
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=CHANGE_ME

# MinIO (S3-compatible Object Storage)
MINIO_USER=komandan
MINIO_PASSWORD=CHANGE_ME

# ==========================================
# DEPLOYMENT CONFIG (ubah saat deploy ke server)
# ==========================================
# Untuk localhost: biarkan kosong
# Untuk IP server: set CORS_ORIGIN ke http://IP:PORT_UI
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
CORS_ORIGIN=http://localhost:3001